<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
    <settings>
        <setting name="mapUnderscoreToCamelCase" value="true"/>
    </settings>
    
    <typeAliases>
        <typeAlias type="com.myfirstproject.mybatis.model.StudentModel" alias="StudentModel"/>
        <typeAlias type="com.myfirstproject.mybatis.model.GroupModel" alias="GroupModel"/>
        <typeAlias type="com.myfirstproject.mybatis.model.SubjectModel" alias="SubjectModel"/>
    </typeAliases>
    
    <environments default="development">
        <environment id="development">
            <transactionManager type="JDBC"/>
            <dataSource type="POOLED">
                <property name="driver" value="org.h2.Driver"/>
                <property name="url" value="jdbc:h2:~/uzd_1;AUTO_SERVER=TRUE"/>
                <property name="username" value="sa"/>
                <property name="password" value=""/>
            </dataSource>
        </environment>
    </environments>
    
    <mappers>
        <mapper resource="mybatis/mappers/StudentMapper.xml"/>
        <mapper resource="mybatis/mappers/GroupMapper.xml"/>
        <mapper resource="mybatis/mappers/SubjectMapper.xml"/>
    </mappers>
</configuration>
